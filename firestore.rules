rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────
    
    // Returns true if the requesting user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Returns true if the requesting user's UID matches the document ID
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── /profiles/{userId} ─────────────────────────────────────────
    match /profiles/{userId} {
      // READ/CREATE: Standard owner access
      allow read, create: if isOwner(userId);

      // UPDATE: Allow updating stats, but LOCK the isPremium field.
      // This prevents users from "hacking" themselves into a Pro subscription.
      allow update: if isOwner(userId) 
                    && (
                      // Only allow the update if isPremium isn't being changed by the client.
                      // Premium status should be handled via a secure Admin SDK or Cloud Function.
                      request.resource.data.isPremium == resource.data.isPremium
                    );

      // DELETE: Required for Google Play / App Store compliance.
      // Users MUST be able to delete their own data.
      allow delete: if isOwner(userId);
    }

    // ─── /leaderboards/{animalId} ───────────────────────────────────
    match /leaderboards/{animalId} {
      // Publicly readable for all hunters
      allow read: if isAuthenticated();

      // PROTECT the Leaderboard from being wiped.
      // We only allow an update if the new list is at least as long as the old one
      // (preventing the "Empty List" wipe hack) and stays within the top 20 limit.
      allow update: if isAuthenticated()
                   && request.resource.data.keys().hasOnly(['scores', 'lastUpdated'])
                   && request.resource.data.scores is list
                   && request.resource.data.scores.size() >= resource.data.scores.size()
                   && request.resource.data.scores.size() <= 20;

      // First-time creation (if a species doesn't have a leaderboard yet)
      allow create: if isAuthenticated() 
                    && request.resource.data.scores.size() <= 20;

      allow delete: if false;
    }

    // ─── /config/{document=**} ─────────────────────────────────────
    match /config/{document=**} {
      allow read: if true;
      allow write: if false; // Admin-only (Version enforcement, etc.)
    }

    // ─── /waitlist/{document} ─────────────────────────────────────
    match /waitlist/{document} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'source', 'timestamp', 'userAgent'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0;
      allow read, update, delete: if false;
    }

    // ─── Deny everything else ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
