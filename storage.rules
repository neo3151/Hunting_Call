rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allows users to view audio files if they are authenticated
    // or if the files are public (e.g. assets)
    match /audio/{allPaths=**} {
      allow read: if request.auth != null;
    }
    
    // Allows users to upload their own recordings/data to a private folder
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: Deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
